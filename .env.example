# Copy to .env.local for dev, and set the same vars in the Cloudflare Pages
# project settings (Production + Preview). Never commit real keys.

# Web3Forms access key, created at https://web3forms.com (tied to your pro email).
# Without it, forms show the confirmation but nothing is sent (a console warning fires).
VITE_WEB3FORMS_KEY=

# IPFS gateway for the Sound Design videos. Defaults to https://gateway.pinata.cloud.
# Set a dedicated gateway for smoother streaming, e.g. https://your-name.mypinata.cloud
VITE_IPFS_GATEWAY=
# Dedicated-gateway access token (Pinata → Gateways, ideally domain-restricted).
# WARNING: this ends up in the public client bundle — use the GATEWAY key only,
# NEVER the pinning JWT.
VITE_IPFS_GATEWAY_TOKEN=

# --- server-only (NOT exposed to the client; used by scripts/pin-to-pinata.sh) ---
# PINATA_JWT=    # put your pinning JWT in .env.local (gitignored), never here

